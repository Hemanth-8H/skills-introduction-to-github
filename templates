<!DOCTYPE html>
<html>

<head>
    <title>Rule-Based URL Detection System</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='style.css') }}">
</head>

<body>
    <video src="{{ url_for('static', filename='background.mp4') }}" autoplay muted loop></video>
    <h1 style="font-size: 70px; color:whitesmoke;font-family:'HK Modular'; text-align:center">URL Detector
    </h1>
    <div class="container">
        <p>Enter a URL to check</p>

        <form method="POST">
            <input type="text" name="url" placeholder="Enter URL here..." required>
            <br>
            <button type="submit">Check URL</button>
        </form>

        {% if result %}
        <div class="result">
            {% if result == "SAFE" %}
            <h2 class="safe">✅ SAFE</h2>
            {% else %}
            <h2 class="unsafe">⚠️ SUSPICIOUS</h2>
            {% endif %}
        </div>
        {% endif %}

    </div>

</body>

</html>
